{"cells": [{"cell_type": "markdown", "metadata": {}, "source": ["# Business Sales Analytics"]}, {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["import pandas as pd\n", "import matplotlib.pyplot as plt\n", "df = pd.read_csv('../data/sales_data.csv')\n", "df['revenue'] = df['quantity'] * df['price']\n", "monthly = df.groupby(df['date'].str[:7])['revenue'].sum()\n", "monthly.plot()\n", "plt.title('Monthly Revenue')\n", "plt.show()"]}], "metadata": {}, "nbformat": 4, "nbformat_minor": 5}